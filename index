    gap: 8px;
  }
  .traffic-lights { display: flex; gap: 8px; align-items: center; }
  .tl { width: 13px; height: 13px; border-radius: 50%; }
  .tl-red { background: #ff5f57; border: 0.5px solid #e0443e; }
  .tl-yellow { background: #febc2e; border: 0.5px solid #d4a017; }
  .tl-green { background: #28c840; border: 0.5px solid #1aab29; }
  .title-text { position: absolute; left: 50%; transform: translateX(-50%); font-size: 13px; font-weight: 600; color: #333; white-space: nowrap; }
  .toolbar {
    height: 44px;
    background: #f8f8f8;
    border-bottom: 1px solid #d8d8d8;
